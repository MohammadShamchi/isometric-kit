{
  "name": "isometric-design",
  "description": "Isometric Kit monorepo: headless auto-layout isometric diagram engine + React components",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohammadShamchi/isometric-kit.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@isometric-design/react",
    "typecheck": "npm run typecheck --workspace=@isometric-design/react",
    "dev": "npm run dev --workspace=demo-react",
    "dev:vanilla": "python3 -m http.server 8080",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
